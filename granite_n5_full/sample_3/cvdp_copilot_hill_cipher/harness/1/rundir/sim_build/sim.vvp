:vpi_module "/usr/local/lib/ivl/va_math.vpi";
:vpi_module "/usr/local/lib/ivl/v2009.vpi";
S_0x1fcfab0 .scope package, "$unit" "$unit" 2 1;
 .timescale -9 -9;
S_0x1fbc960 .scope module, "hill_cipher" "hill_cipher" 3 1;
 .timescale -9 -9;
    .port_info 0 /INPUT 1 "clk";
    .port_info 1 /INPUT 1 "reset";
    .port_info 2 /INPUT 1 "start";
    .port_info 3 /INPUT 5 "plaintext";
    .port_info 4 /INPUT 45 "key";
    .port_info 5 /OUTPUT 15 "ciphertext";
    .port_info 6 /OUTPUT 1 "done";
v0x1fbcd70_0 .var "ciphertext", 14 0;
o0x7db602095048 .functor BUFZ 1, c4<z>; HiZ drive
v0x1ff1af0_0 .net "clk", 0 0, o0x7db602095048;  0 drivers
v0x1ff1bb0_0 .var "done", 0 0;
o0x7db6020950a8 .functor BUFZ 45, c4<zzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzz>; HiZ drive
v0x1ff1c50_0 .net "key", 44 0, o0x7db6020950a8;  0 drivers
o0x7db6020950d8 .functor BUFZ 5, c4<zzzzz>; HiZ drive
v0x1ff1d30_0 .net "plaintext", 4 0, o0x7db6020950d8;  0 drivers
o0x7db602095108 .functor BUFZ 1, c4<z>; HiZ drive
v0x1ff1e60_0 .net "reset", 0 0, o0x7db602095108;  0 drivers
o0x7db602095138 .functor BUFZ 1, c4<z>; HiZ drive
v0x1ff1f20_0 .net "start", 0 0, o0x7db602095138;  0 drivers
S_0x1fbcbe0 .scope module, "cocotb_iverilog_dump" "cocotb_iverilog_dump" 4 1;
 .timescale -9 -9;
    .scope S_0x1fbcbe0;
T_0 ;
    %vpi_call/w 4 3 "$dumpfile", "/code/rundir/sim_build/hill_cipher.fst" {0 0 0};
    %vpi_call/w 4 4 "$dumpvars", 32'sb00000000000000000000000000000000, S_0x1fbc960 {0 0 0};
    %end;
    .thread T_0;
